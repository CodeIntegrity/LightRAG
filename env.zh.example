#######################################################################################
### Embedding 配置（处理第一个文件之后不要再修改）
### EMBEDDING_BINDING：ollama、openai、azure_openai、jina、lollms、aws_bedrock
### EMBEDDING_BINDING_HOST：服务端点（如果使用 openai 或 gemini SDK 提供的默认端点，可留空）
### EMBEDDING_BINDING_API_KEY：API 密钥
### 如果 LightRAG 运行在 Docker 中：
###    EMBEDDING_BINDING_HOST 中请使用 host.docker.internal，而不是 localhost
### 控制是否向 embedding API 发送 embedding_dim 参数
###    对 OpenAI：设为 EMBEDDING_SEND_DIM=true 以启用动态维度调整
###    对 OpenAI：设为 EMBEDDING_SEND_DIM=false（默认）以禁用发送 dimension 参数
###    对 Gemini：始终应设置 EMBEDDING_SEND_DIM=true
### 控制 embeddings 是否使用 base64 编码格式（对 OpenAI 可提升性能）
###    对 OpenAI：设为 EMBEDDING_USE_BASE64=true（默认）以使用 base64 编码
###    对 Yandex Cloud 等不支持该格式的 provider：设为 false
#######################################################################################
# EMBEDDING_TIMEOUT=30

### OpenAI 兼容 embedding
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=your_api_key
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=false
# EMBEDDING_USE_BASE64=true

