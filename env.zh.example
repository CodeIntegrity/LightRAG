# # EMBEDDING_BINDING_API_KEY=your_api_key
# # EMBEDDING_MODEL=my-text-embedding-3-large-deployment
# # EMBEDDING_DIM=3072
# AZURE_EMBEDDING_API_VERSION=2024-08-01-preview
### 可选的 Azure 原生别名，便于 SDK 兼容
# AZURE_EMBEDDING_ENDPOINT=https://xxxx.openai.azure.com/
# AZURE_EMBEDDING_API_KEY=your_api_key
# AZURE_EMBEDDING_DEPLOYMENT=my-text-embedding-3-large-deployment

