### Langfuse 可观测性配置
### 仅在 LLM 由 OpenAI 兼容 API 提供时生效
### 安装方式：pip install lightrag-hku[observability]
### 注册地址：https://cloud.langfuse.com 或自行部署
###########################################################
# LANGFUSE_SECRET_KEY=""
# LANGFUSE_PUBLIC_KEY=""
# LANGFUSE_HOST="https://cloud.langfuse.com"
# LANGFUSE_ENABLE_TRACE=true

############################
### 评估配置
############################
### RAGAS 评估模型（用于 RAG 质量评估）
### ⚠️ 重要：LLM 和 Embedding 的端点都必须兼容 OpenAI
### 默认使用 OpenAI 模型进行评估

### 评估用 LLM 配置
# EVAL_LLM_MODEL=gpt-4o-mini
### LLM 评估 API key（未设置时回退到 OPENAI_API_KEY）
# EVAL_LLM_BINDING_API_KEY=your_api_key
### 用于 LLM 评估的自定义 OpenAI 兼容端点（可选）
# EVAL_LLM_BINDING_HOST=https://api.openai.com/v1
### 待评估的 LightRAG API 端点
# LIGHTRAG_API_URL=http://localhost:9621

### 评估用 Embedding 配置
# EVAL_EMBEDDING_MODEL=text-embedding-3-large
### Embedding API key（回退顺序：EVAL_LLM_BINDING_API_KEY -> OPENAI_API_KEY）
# EVAL_EMBEDDING_BINDING_API_KEY=your_embedding_api_key
### 用于 Embedding 的自定义 OpenAI 兼容端点（回退到 EVAL_LLM_BINDING_HOST）
# EVAL_EMBEDDING_BINDING_HOST=https://api.openai.com/v1

### 性能调优
### 测试用例评估的并发数
### 较低的值可以减少 API 限流问题，但会增加评估耗时
# EVAL_MAX_CONCURRENT=2
### LightRAG 的 TOP_K 查询参数（默认：10）
### 从 KG 中检索的实体或关系数量
# EVAL_QUERY_TOP_K=10
### 评估用 LLM 的重试和超时设置
# EVAL_LLM_MAX_RETRIES=5
# EVAL_LLM_TIMEOUT=180

#############################################
### SDK / 兼容别名环境变量
### 正常的 lightrag-server 配置通常不需要这些项
#############################################
### 旧版 OpenAI SDK 的 base URL 别名；LightRAG 服务端优先使用 LLM_BINDING_HOST
# OPENAI_API_BASE=https://api.openai.com/v1
### 供独立 provider/helper 模块使用的可选 API 密钥
# ANTHROPIC_API_KEY=your_anthropic_api_key
# VOYAGE_API_KEY=your_voyage_api_key
# VOYAGEAI_API_KEY=your_voyage_api_key
### 仅 macOS + Gunicorn 场景需要：若出现 fork-safety 警告，可设为 YES
# OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES
### 本地 helper 模块可选的 HuggingFace tokenizer 并行开关
# TOKENIZERS_PARALLELISM=false
