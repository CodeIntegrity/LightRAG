### PostgreSQL 配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_username
POSTGRES_PASSWORD='your_password'
POSTGRES_DATABASE=rag
POSTGRES_MAX_CONNECTIONS=12
### 不应设置数据库专属 workspace，此项仅为兼容旧配置保留
# POSTGRES_WORKSPACE=forced_workspace_name


### 对大维度 embedding（2000+ 维）建议使用 HNSW_HALFVEC。
### 需要 pgvector 扩展版本 >= 0.7.0。
### 向量索引类型：HNSW、HNSW_HALFVEC、IVFFlat、VCHORDRQ
POSTGRES_VECTOR_INDEX_TYPE=HNSW
POSTGRES_HNSW_M=16
POSTGRES_HNSW_EF=200
POSTGRES_IVFFLAT_LISTS=100
POSTGRES_VCHORDRQ_BUILD_OPTIONS=
POSTGRES_VCHORDRQ_PROBES=
POSTGRES_VCHORDRQ_EPSILON=1.9

### PostgreSQL 连接重试配置（增强网络健壮性）
### 新默认值（v1.4.10+）：针对切换时间约 30 秒的 HA 部署优化
### 这些默认值可为 PostgreSQL 高可用部署提供开箱即用支持
###
### 重试次数（1-100，默认：10）
###   - 默认 10 次重试可提供约 225 秒总重试时间（足够覆盖大多数 HA 场景）
###   - 极端情况下可提高到 20-50
### 初始重试退避秒数（0.1-300.0，默认：3.0）
###   - 默认 3.0 秒可提供较合理的初始延迟，用于探测切换完成
###   - 如果想更快恢复，可降到 1.0-2.0
### 最大重试退避秒数（必须 >= backoff，最大：600.0，默认：30.0）
###   - 默认 30.0 秒与常见切换完成时间相匹配
###   - 若切换耗时更长，可增大到 60-90
### 连接池关闭超时秒数（1.0-30.0，默认：5.0）
# POSTGRES_CONNECTION_RETRIES=10
# POSTGRES_CONNECTION_RETRY_BACKOFF=3.0
# POSTGRES_CONNECTION_RETRY_BACKOFF_MAX=30.0
# POSTGRES_POOL_CLOSE_TIMEOUT=5.0

### PostgreSQL SSL 配置（可选）
# POSTGRES_SSL_MODE=require
# POSTGRES_SSL_CERT=/path/to/client-cert.pem
# POSTGRES_SSL_KEY=/path/to/client-key.pem
# POSTGRES_SSL_ROOT_CERT=/path/to/ca-cert.pem
# POSTGRES_SSL_CRL=/path/to/crl.pem

### PostgreSQL 服务端设置（用于 Supabase Supavisor）
# 使用该项把额外选项传入 PostgreSQL 连接串。
# 对于 Supabase，可能需要这样设置：
# POSTGRES_SERVER_SETTINGS="options=reference%3D[project-ref]"

# 默认值为 100；设为 0 可禁用
# POSTGRES_STATEMENT_CACHE_SIZE=100

### Neo4j 配置
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD='your_password'
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=100
NEO4J_CONNECTION_TIMEOUT=30
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=30
NEO4J_MAX_TRANSACTION_RETRY_TIME=30
NEO4J_MAX_CONNECTION_LIFETIME=300
NEO4J_LIVENESS_CHECK_TIMEOUT=30
NEO4J_KEEP_ALIVE=true
### 不应设置数据库专属 workspace，此项仅为兼容旧配置保留
# NEO4J_WORKSPACE=forced_workspace_name

### MongoDB 配置
# 对于 MongoVectorDBStorage，MONGO_URI 必须指向支持 Atlas Search / Vector Search 的 MongoDB 端点，例如 MongoDB Atlas 或 Atlas local。
MONGO_URI=mongodb://localhost:27017/
MONGO_DATABASE=LightRAG
### MongoGraphStorage 的图遍历模式：bidirectional 或 in_out_bound
# MONGO_GRAPH_BFS_MODE=bidirectional
### 不应设置数据库专属 workspace，此项仅为兼容旧配置保留
# MONGODB_WORKSPACE=forced_workspace_name

# 社区版/本地 Docker MongoDB 示例，仅适用于 KV、graph 或 doc-status 存储：
# MONGO_URI=mongodb://localhost:27017/

### OpenSearch 配置
### OpenSearch 可用于全部存储类型：KV、Vector、Graph、DocStatus
# # LIGHTRAG_KV_STORAGE=OpenSearchKVStorage
# # LIGHTRAG_DOC_STATUS_STORAGE=OpenSearchDocStatusStorage
# # LIGHTRAG_GRAPH_STORAGE=OpenSearchGraphStorage
# # LIGHTRAG_VECTOR_STORAGE=OpenSearchVectorDBStorage
### 连接设置（多个 host:port 用逗号分隔；不要包含 http:// 或 https://）
### 当前 setup 向导只支持启用鉴权的 OpenSearch 集群。
### OPENSEARCH_USE_SSL 控制这些主机是否通过 TLS 访问。
OPENSEARCH_HOSTS=localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=LightRAG2026_!@
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=false
# OPENSEARCH_TIMEOUT=30
# OPENSEARCH_MAX_RETRIES=3
### 索引设置（如果使用 3 可用区 Amazon OpenSearch Service，副本数建议设为 2）
# OPENSEARCH_NUMBER_OF_SHARDS=1
# OPENSEARCH_NUMBER_OF_REPLICAS=0
### 向量存储的 k-NN 设置（HNSW 算法）
# OPENSEARCH_KNN_EF_CONSTRUCTION=200
# OPENSEARCH_KNN_M=16
# OPENSEARCH_KNN_EF_SEARCH=100
### 使用 PPL graphlookup 进行服务端图遍历（未设置时自动检测）
# OPENSEARCH_USE_PPL_GRAPHLOOKUP=true
### 不应设置数据库专属 workspace，此项仅为兼容旧配置保留
# OPENSEARCH_WORKSPACE=forced_workspace_name

### Milvus 配置
MILVUS_URI=http://localhost:19530
MILVUS_DB_NAME=lightrag
# MILVUS_DEVICE=cpu
# MILVUS_USER=root
# MILVUS_PASSWORD=your_password
# MILVUS_TOKEN=your_token
# 这是仓库内置 Docker Milvus 栈所必需的配置；值可来自 .env 或导出的 shell 变量。
# MINIO_ACCESS_KEY_ID=minioadmin
# MINIO_SECRET_ACCESS_KEY=minioadmin
### 不应设置数据库专属 workspace，此项仅为兼容旧配置保留
# MILVUS_WORKSPACE=forced_workspace_name

### Milvus 向量索引配置
### 索引类型：AUTOINDEX（默认）、HNSW、HNSW_SQ、HNSW_PQ、IVF_FLAT、IVF_SQ8、DISKANN
# MILVUS_INDEX_TYPE=AUTOINDEX

### 距离度量类型：COSINE（默认）、L2、IP
# MILVUS_METRIC_TYPE=COSINE

### HNSW / HNSW_SQ / HNSW_PQ 参数（与 Milvus 2.4+ 默认值对齐）
### M：每个节点的最大连接数 [2-2048]，默认 16
# MILVUS_HNSW_M=16
### efConstruction：构建时动态候选列表大小 [8-512]，默认 360
# MILVUS_HNSW_EF_CONSTRUCTION=360
### ef：检索时动态候选列表大小，默认 200
# MILVUS_HNSW_EF=200

### HNSW_SQ 专属参数（需要 Milvus 2.6.8+）
### sq_type：标量量化类型，可选 SQ4U、SQ6、SQ8（默认）、BF16、FP16
# MILVUS_HNSW_SQ_TYPE=SQ8
### refine：是否启用精炼步骤以提高精度，默认 false
# MILVUS_HNSW_SQ_REFINE=false
### refine_type：精炼精度（必须高于 sq_type），可选 SQ6、SQ8、BF16、FP16、FP32
# MILVUS_HNSW_SQ_REFINE_TYPE=FP32
### refine_k：精炼扩展因子，默认 10
# MILVUS_HNSW_SQ_REFINE_K=10

### IVF_FLAT / IVF_SQ8 参数
### nlist：聚类单元数量 [1-65536]，当 n>1M 时建议设为 sqrt(n)，默认 1024
# MILVUS_IVF_NLIST=1024
### nprobe：查询时扫描的单元数量 [1-nlist]，默认 16
# MILVUS_IVF_NPROBE=16

### Qdrant
QDRANT_URL=http://localhost:6333
# QDRANT_DEVICE=cpu
# QDRANT_API_KEY=your-api-key
### Qdrant upsert 分批配置（默认启用）
### 根据估算的 JSON 负载大小和 point 数量拆分大批量 upsert
### 默认 16MB 可在常见 32MB 网关/请求限制下保留安全余量
# QDRANT_UPSERT_MAX_PAYLOAD_BYTES=16777216
# QDRANT_UPSERT_MAX_POINTS_PER_BATCH=128
### 不应设置数据库专属 workspace，此项仅为兼容旧配置保留
# QDRANT_WORKSPACE=forced_workspace_name

### Redis
REDIS_URI=redis://localhost:6379
REDIS_SOCKET_TIMEOUT=30
REDIS_CONNECT_TIMEOUT=10
REDIS_MAX_CONNECTIONS=100
REDIS_RETRY_ATTEMPTS=3
### 不应设置数据库专属 workspace，此项仅为兼容旧配置保留
# REDIS_WORKSPACE=forced_workspace_name

### NebulaGraph 配置
### 如有需要，可通过环境变量选择 NebulaGraphStorage：
# LIGHTRAG_GRAPH_STORAGE=NebulaGraphStorage
NEBULA_HOSTS=127.0.0.1:9669
NEBULA_USER=root
### 如果你的 NebulaGraph 部署允许，密码可以留空
NEBULA_PASSWORD=nebula
### 可选：设置专用的 workspace 覆盖值或 space 前缀
# NEBULA_WORKSPACE=forced_workspace_name
# NEBULA_SPACE_PREFIX=lightrag
### 可选：为新建的 spaces 指定分区数和副本因子
# NEBULA_SPACE_PARTITIONS=10
# NEBULA_SPACE_REPLICA_FACTOR=1
### 可选但推荐：当使用 Nebula 全文检索时，
### 提供 listener host，使新建 workspace 能自动注册 listeners
# NEBULA_LISTENER_HOSTS=172.28.0.10:9789
### 面向旧部署的可选回退：
### 只有在你希望启动时扫描其他 space 复用 listener 地址时才开启
# NEBULA_LISTENER_DISCOVERY=false
### search_labels 的全文检索质量依赖于
### 由 Elasticsearch + Listener 支撑的 NebulaGraph Full-Text 服务。
### 如果没有该服务，search_labels 会退化为子串匹配。
### 传输和连接调优
### 当 graphd 已配置 TLS/SSL 时，可开启 Nebula TLS/SSL 传输
# NEBULA_SSL=false
# NEBULA_USE_HTTP2=false
# NEBULA_TIMEOUT_MS=60000
# NEBULA_MAX_CONNECTION_POOL_SIZE=100

### Memgraph 配置
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=
MEMGRAPH_DATABASE=memgraph
### 不应设置数据库专属 workspace，此项仅为兼容旧配置保留
# MEMGRAPH_WORKSPACE=forced_workspace_name

