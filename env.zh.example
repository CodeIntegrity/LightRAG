### 所有可配置的环境变量都必须在此示例文件中以启用或注释状态出现
### Setup 工具 `make env-*` 会使用此文件生成最终的 .env 文件
### 这些只是占位示例，setup 工具不应把这些行替换成实际值。

### 此 env 文件的目标环境：host/compose（compose 用于 Docker 或 Kubernetes）
# LIGHTRAG_RUNTIME_TARGET=host

###########################
### 服务端配置
###########################
HOST=0.0.0.0
PORT=9621
WEBUI_TITLE='My Graph KB'
WEBUI_DESCRIPTION='Simple and Fast Graph Based RAG System'
# WORKERS=2
### gunicorn worker 超时（如果未设置 LLM_TIMEOUT，则也作为默认 LLM 请求超时）
# TIMEOUT=150
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

### 路径前缀配置（可选）
### 用于在同一主机上通过反向代理路径前缀托管多个 LightRAG 实例。
### 若为单实例部署，请留空或不设置。
###
### - LIGHTRAG_API_PREFIX  : 上游反向代理在转发前会剥离的路径前缀
###                          （FastAPI 通过 root_path 感知它）
###
### 端到端示例见 docs/MultiSiteDeployment.md。
# LIGHTRAG_API_PREFIX=/site01

### 可选的 SSL 配置
### Docker 说明：生成的 compose 文件会把预备好的证书挂载到容器内的 /app/data/certs/
# SSL=true
# SSL_CERTFILE=/path/to/cert.pem
# SSL_KEYFILE=/path/to/key.pem

### 目录配置（默认使用当前工作目录）
### 默认值：./inputs ./rag_storage ./prompts
# INPUT_DIR=<absolute_path_for_doc_input_dir>
# WORKING_DIR=<absolute_path_for_working_dir>
# PROMPT_DIR=<absolute_path_for_prompt_dir>

### Tiktoken 缓存目录（离线部署时将缓存文件存放在这里）
# TIKTOKEN_CACHE_DIR=/app/data/tiktoken

### Ollama 模拟模型名和 Tag
# OLLAMA_EMULATING_MODEL_NAME=lightrag
OLLAMA_EMULATING_MODEL_TAG=latest

### 图检索最大节点数（请同时确认 WebUI 本地设置中的上限也与此值一致）
# MAX_GRAPH_NODES=1000

### 日志级别
# LOG_LEVEL=INFO
# VERBOSE=False
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5
### 日志文件位置（默认使用当前工作目录）
# LOG_DIR=/path/to/log/directory
# LIGHTRAG_PERFORMANCE_TIMING_LOGS=false

#####################################
### 登录与 API-Key 配置
#####################################
# AUTH_ACCOUNTS='admin:admin123,user1:{bcrypt}$2b$12$S8Yu.gCbuAbNTJFB.231gegTwr5pgrFxc8H9kXQ4/sduFBHkhM8Ka'
# TOKEN_SECRET=lightrag-jwt-default-secret-key!
# JWT_ALGORITHM=HS256
# TOKEN_EXPIRE_HOURS=48
# GUEST_TOKEN_EXPIRE_HOURS=24

### Token 自动续期配置（滑动窗口过期）
### 开启后可防止活跃用户被自动登出
### 当剩余有效期小于阈值时会自动续期
# TOKEN_AUTO_RENEW=true
### Token 续期阈值（0.0 - 1.0）
### 当剩余时间 <（总时长 * 阈值）时触发续期
### 默认：0.5（剩余 50% 时间时续期）
### 示例：
###   0.5 = 24h token 剩余 12h 时续期
###   0.25 = 24h token 剩余 6h 时续期
# TOKEN_RENEW_THRESHOLD=0.5
### 注意：以下接口会自动跳过 Token 续期：
###   - /health：健康检查接口（无需鉴权）
###   - /documents/paginated：客户端高频轮询（5-30 秒间隔）
###   - /documents/pipeline_status：客户端超高频轮询（2 秒间隔）
###   - 速率限制：同一用户两次续期之间至少间隔 60 秒

### 访问 LightRAG Server API 的 API-Key
### 在 HTTP 请求头中使用 'X-API-Key' 传递该密钥
### 示例：curl -H "X-API-Key: your-secure-api-key-here" http://localhost:9621/query
# LIGHTRAG_API_KEY=your-secure-api-key-here
# WHITELIST_PATHS=/health,/api/*

######################################################################################
### 查询配置
###
### 如何控制发送给 LLM 的上下文长度：
###    MAX_ENTITY_TOKENS + MAX_RELATION_TOKENS < MAX_TOTAL_TOKENS
###    Chunk_Tokens = MAX_TOTAL_TOKENS - Actual_Entity_Tokens - Actual_Relation_Tokens
######################################################################################
# 查询阶段的 LLM 响应缓存（流式响应时无效）
# ENABLE_LLM_CACHE=true
# COSINE_THRESHOLD=0.2
### 从知识图谱中检索的实体或关系数量
# TOP_K=40
### 朴素向量检索时返回的最大 chunk 数量
# CHUNK_TOP_K=20
### 控制实际发送给 LLM 的实体 token 数
# MAX_ENTITY_TOKENS=6000
### 控制实际发送给 LLM 的关系 token 数
# MAX_RELATION_TOKENS=8000
### 控制发送给 LLM 的最大 token 数（包含实体、关系和 chunks）
# MAX_TOTAL_TOKENS=30000

### chunk 选择策略
###     VECTOR：按向量相似度挑选 KG chunks，送给 LLM 的 chunks 更接近朴素检索结果
###     WEIGHT：按实体和 chunk 权重挑选 KG chunks，送给 LLM 的 chunks 更偏知识图谱相关
###     如果启用了重排序，chunk 选择策略的影响会减弱。
# KG_CHUNK_PICK_METHOD=VECTOR

### 每个源实体或关系关联的最大 chunk 数
###     chunk 选择器会用这个值确定从知识图谱中总共选取多少 chunks
###     值越大，重排序耗时越高
# RELATED_CHUNK_NUMBER=5

#########################################################
### 重排序配置
### RERANK_BINDING 类型：null、cohere、jina、aliyun
### 如果使用 vLLM 部署重排序模型，请使用 cohere binding
### 如果 LightRAG 运行在 Docker 中：
###    RERANK_BINDING_HOST 中请使用 host.docker.internal，而不是 localhost
#########################################################
RERANK_BINDING=null
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_BINDING_HOST=http://localhost:8000/rerank
# RERANK_BINDING_API_KEY=your_rerank_api_key_here

### 重排序分数过滤阈值（设为 0.0 表示保留全部 chunks；如果 LLM 能力较弱，建议 0.6 或更高）
# MIN_RERANK_SCORE=0.0
### 当 RERANK_BINDING 不为 null 时，是否默认在查询参数中开启重排序
# RERANK_BY_DEFAULT=True

### 重排序并发数与超时（独立于基础 LLM 设置）
### MAX_ASYNC_RERANK 未设置时回退到 MAX_ASYNC。
### RERANK_TIMEOUT 有独立默认值（30s），因为重排序调用
### 通常比完整 LLM 生成短得多。
# MAX_ASYNC_RERANK=4
# RERANK_TIMEOUT=30

### Cohere AI
# # RERANK_MODEL=rerank-v3.5
# # RERANK_BINDING_HOST=https://api.cohere.com/v2/rerank
# # RERANK_BINDING_API_KEY=your_rerank_api_key_here
### Cohere 重排序的分块配置（对 ColBERT 这类有 token 限制的模型有帮助）
# RERANK_ENABLE_CHUNKING=true
# RERANK_MAX_TOKENS_PER_DOC=480

### 阿里云 Dashscope
# # RERANK_MODEL=gte-rerank-v2
# # RERANK_BINDING_HOST=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
# # RERANK_BINDING_API_KEY=your_rerank_api_key_here

### Jina AI
# # RERANK_MODEL=jina-reranker-v2-base-multilingual
# # RERANK_BINDING_HOST=https://api.jina.ai/v1/rerank
# # RERANK_BINDING_API_KEY=your_rerank_api_key_here

### 用于本地部署的 vLLM Embedding 与 Reranker（OpenAI 兼容 API）
### 向导元数据：用于在多次运行 setup 时保留所选部署提供方
# LIGHTRAG_SETUP_EMBEDDING_PROVIDER=vllm
# LIGHTRAG_SETUP_RERANK_PROVIDER=vllm
# VLLM_EMBED_MODEL=BAAI/bge-m3
# VLLM_EMBED_PORT=8001
# VLLM_EMBED_DEVICE=cpu
### VLLM_EMBED_API_KEY 会作为 --api-key 传给 vLLM；并同步到 EMBEDDING_BINDING_API_KEY；留空时自动生成
# VLLM_EMBED_API_KEY=
# VLLM_EMBED_EXTRA_ARGS=
# VLLM_RERANK_MODEL=BAAI/bge-reranker-v2-m3
# VLLM_RERANK_PORT=8000
# VLLM_RERANK_DEVICE=cuda
### VLLM_RERANK_API_KEY 会作为 --api-key 传给 vLLM；并同步到 RERANK_BINDING_API_KEY；留空时自动生成
# VLLM_RERANK_API_KEY=
### GPU 模式建议使用 float16。CPU 模式使用官方 vLLM CPU 镜像。
# VLLM_USE_CPU=1
### 设为 1 表示 CPU 模式；不设置表示 GPU 模式
# CUDA_VISIBLE_DEVICES=-1
### 设为 -1 可禁用 CUDA（CPU 模式），或设置具体 GPU ID 以启用 GPU 模式
# NVIDIA_VISIBLE_DEVICES=0
### 可选的 Docker 运行时等价变量；生成的 GPU compose 文件会兼容其中任一变量。
# VLLM_RERANK_EXTRA_ARGS=

########################################
### 文档处理配置
########################################
ENABLE_LLM_CACHE_FOR_EXTRACT=true

### 文档处理输出语言：English、Chinese、French、German ...
SUMMARY_LANGUAGE=English

### 文件上传大小限制（单位：字节）
### 默认：104857600（100MB）
### 设为 0 或 None 表示不限制上传大小
### 示例：
###   52428800  = 50MB
###   104857600 = 100MB（默认）
###   209715200 = 200MB
### 注意：如果使用 Nginx 作为反向代理，也请同时配置 client_max_body_size
# MAX_UPLOAD_SIZE=104857600

### 文档切块大小，建议范围 500~1500
# CHUNK_SIZE=1200
# CHUNK_OVERLAP_SIZE=100

### 固定 token 分块器（process_options=F，默认）设置
###     CHUNK_F_OVERLAP_SIZE：token 重叠；未设置时回退到 CHUNK_OVERLAP_SIZE
###     CHUNK_F_SPLIT_BY_CHARACTER：可选的分隔符字符串；在 token 窗口化之前预分段
###     CHUNK_F_SPLIT_BY_CHARACTER_ONLY：为 true 时，超大段直接报错而非 token 重分割
# CHUNK_F_OVERLAP_SIZE=100
# CHUNK_F_SPLIT_BY_CHARACTER=
# CHUNK_F_SPLIT_BY_CHARACTER_ONLY=false

### 递归字符分块器（process_options=R）设置
###     CHUNK_R_SIZE：策略专属 chunk_token_size 覆盖；未设置时回退到 CHUNK_SIZE
###     CHUNK_R_OVERLAP_SIZE：相邻 chunk 间的 token 重叠；未设置时回退到 CHUNK_OVERLAP_SIZE
###     CHUNK_R_SEPARATORS：RecursiveCharacterTextSplitter 尝试的级联分隔符 JSON 数组。
###       默认包含 CJK 句末标点，使中文/混合语言文档
###       在语义边界处切分。顺序：段落（\n\n）> 行（\n）>
###       中文句末（。！？） > 中文半句（；，） > 空格 > 字符。
###       英文 ".?!" 被有意省略（字面匹配会错误分割 "0.95" /
###       "e.g."）；英文路径仍通过空格/字符回退处理。
# CHUNK_R_SIZE=1200
# CHUNK_R_OVERLAP_SIZE=100
# CHUNK_R_SEPARATORS=["\n\n","\n","。","！","？","；","，"," ",""]

### 语义向量分块器（process_options=V）设置
###     CHUNK_V_SIZE：策略专属 chunk_token_size 硬上限（超大块在
###       输出前会通过 R 策略重分割）；未设置时回退到 CHUNK_SIZE
###     CHUNK_V_BREAKPOINT_THRESHOLD_TYPE：percentile | standard_deviation | interquartile | gradient
###     CHUNK_V_BREAKPOINT_THRESHOLD_AMOUNT：留空使用 LangChain 各类型默认值（如 percentile 默认 95）
###     CHUNK_V_BUFFER_SIZE：计算距离时合并的相邻句子数
###     CHUNK_V_SENTENCE_SPLIT_REGEX：传递给 LangChain SemanticChunker 的
###       初始句子分割正则。默认扩展了上游仅英文的模式，
###       加入了 CJK 句末标点（。？！）。如需其他语言组合可覆盖。
###       注意：环境变量值应为原始正则字符串，不需要 JSON 引号。
# CHUNK_V_SIZE=1200
# CHUNK_V_BREAKPOINT_THRESHOLD_TYPE=percentile
# CHUNK_V_BREAKPOINT_THRESHOLD_AMOUNT=
# CHUNK_V_BUFFER_SIZE=1
# CHUNK_V_SENTENCE_SPLIT_REGEX=(?<=[.?!])\s+|(?<=[。？！])

### 段落语义分块器（process_options=P）设置
###     CHUNK_P_SIZE：策略专属 chunk_token_size 覆盖；未设置时默认 2000
###       （不会回退到 CHUNK_SIZE —— 段落语义合并需要比全局默认值更大的
###       余量来保持相关段落在一起）。
###     CHUNK_P_OVERLAP_SIZE：散文回退和表格桥接上下文的重叠；未设置时回退到 CHUNK_OVERLAP_SIZE
# CHUNK_P_SIZE=2000
# CHUNK_P_OVERLAP_SIZE=100

### 多模态解析/分析集成
### 可选的解析器路由规则，例如：
###   LIGHTRAG_PARSER=pdf:mineru,docx:docling,pptx:docling,xlsx:docling,*:legacy
### 规则可用逗号或分号分隔。规则匹配文件后缀名
### （如 pdf），而不是完整文件名（*.pdf），从左到右依次匹配。
### 如果 LIGHTRAG_PARSER 中出现了 mineru/docling，必须在服务启动前
### 配置好以下对应的端点。
### 详见 docs/FileProcessingPipeline.md
LIGHTRAG_PARSER=*:native-teP,*:legacy-R

### 异步解析服务协议（可选）
### 使用远程 MinerU/Docling 异步服务时配置此项

### ---- MinerU 共享参数（本地和官方模式通用） ----
### MinerU API 协议。选择一个启用模式。
### - official：MinerU 精密 API v4，需要 MINERU_API_TOKEN。
### - local：自部署的 mineru-api / mineru-router。
MINERU_API_MODE=local
# MINERU_POLL_INTERVAL_SECONDS=2
# MINERU_MAX_POLLS=180
# MINERU_LANGUAGE=ch
# MINERU_ENABLE_TABLE=true
# MINERU_ENABLE_FORMULA=true
# MINERU_PAGE_RANGES=
### MINERU_PAGE_RANGES 语义因模式不同而不同：
### - official：原样转发，支持如 "1-3,5,7-9" 的格式。
### - local：只支持单页（"3"）或简单范围（"1-10"）；逗号
###             列表会在启动时被拒绝。
### 切换模式时请检查此约束。

### ---- MinerU 本地专用（MINERU_API_MODE=local） ----
MINERU_LOCAL_ENDPOINT=http://127.0.0.1:8000
### MINERU_LOCAL_BACKEND：由哪个 mineru-api 后端处理解析。
###   可接受的值（对应 mineru-api POST /tasks 表单参数 `backend`）：
###     hybrid-auto-engine - pipeline + VLM 组合，自动选择本地
###                          引擎（mineru-api 默认值）。需要 GPU。
###     pipeline           - 适合 CPU 的传统 pipeline；无 VLM 步骤。
###     vlm-auto-engine    - VLM，自动选择本地推理引擎
###                          （sglang-engine / vllm-engine，如果有 GPU）；
###                          需要 mineru-api 端预装匹配的引擎扩展
###                          以及模型权重。
###   我们提供 `hybrid-auto-engine` —— 需要目标 mineru-api
###   部署具有 GPU 及匹配的推理引擎
###   （sglang / vllm）和模型权重。对于没有这些依赖的
###   纯 CPU 部署，请切换到 `pipeline`。
MINERU_LOCAL_BACKEND=hybrid-auto-engine
### MINERU_LOCAL_PARSE_METHOD：pipeline 组件的解析策略。
###   可接受的值：
###     auto - 每页自动检测内嵌文本层 vs OCR（默认）。
###     txt  - 仅从内嵌文本层提取文本；最快，
###            但对无文本层的扫描 PDF 会输出空结果。
###     ocr  - 无论文本层质量如何强制对每页 OCR；
###            最慢，但对扫描或低质量 PDF 可靠。
###   仅在 MINERU_LOCAL_BACKEND 为 `pipeline` 或
###   `hybrid-auto-engine`（混合 pipeline 的 pipeline 分支）时生效。
###   纯 VLM 后端（`vlm-auto-engine`、`vlm-http-client`）忽略此
###   参数 —— VLM 模型原生处理布局/OCR。
MINERU_LOCAL_PARSE_METHOD=auto
### MINERU_LOCAL_IMAGE_ANALYSIS：启用 VLM 图像/图表分析。
###   仅在 `vlm-auto-engine`、`vlm-http-client`、
###   `hybrid-auto-engine`、`hybrid-http-client` 后端中生效。`pipeline` 后端
###   会静默忽略此标志 —— 其 `_process_pipeline` 不接受
###   该参数，因此在 pipeline 下设为 `false` 不会加快解析速度；
###   pipeline 从一开始就不会调用 VLM 图像分析。
###   在 VLM / 混合后端上禁用（`false`）可跳过额外的 VLM
###   轮次，以牺牲图像/图表语义描述为代价换取更快的解析速度
###   和更低的 GPU 成本。
MINERU_LOCAL_IMAGE_ANALYSIS=true
# MINERU_LOCAL_START_PAGE_ID=0
# MINERU_LOCAL_END_PAGE_ID=99999

### ---- MinerU 官方专用（MINERU_API_MODE=official） ----
# MINERU_API_TOKEN=your-api-key
# MINERU_OFFICIAL_ENDPOINT=https://mineru.net
# MINERU_MODEL_VERSION=vlm
# MINERU_IS_OCR=false

### MinerU 原始包处理（随统一 sidecar pipeline 引入）。
### - MINERU_IMAGE_URL_TEMPLATE：可选的 content_list 图片引用回退模板
###     用于下载的 zip 中不存在的图片。支持 {name} 和 {path}。
### - MINERU_ENGINE_VERSION：记录在 <base>.mineru_raw/_manifest.json 中。
###     与记录值不匹配时会强制缓存过期 → 重新下载。
###     留空跳过此检查。
### - LIGHTRAG_FORCE_REPARSE_MINERU：为 truthy 值（"1"/"true"）时，绕过
###     mineru 原始缓存，每次 parse_mineru 调用都重新上传。
# MINERU_IMAGE_URL_TEMPLATE=
# MINERU_ENGINE_VERSION=
# LIGHTRAG_FORCE_REPARSE_MINERU=false

### Docling 解析器（docling-serve v1 / 异步 API）。
###
### Endpoint: base URL only — the client appends /v1/convert/file/async,
###     /v1/status/poll/{task_id}?wait=<DOCLING_POLL_INTERVAL_SECONDS>,
###     /v1/result/{task_id} itself.
### Pipeline shape (pipeline=standard, target_type=zip,
###     to_formats=[json,md], image_export_mode=referenced) is fixed in
###     code so the sidecar flow stays self-consistent — flipping any of
###     these would break the adapter and is therefore not exposed as env.
###
### OCR tunables:
### - DOCLING_DO_OCR: master switch; when false the engine relies only on
###     text-layer extraction.
### - DOCLING_FORCE_OCR: when true, OCR every page regardless of text-layer
###     quality (slower, useful for scanned PDFs with bad text layers).
### - DOCLING_OCR_ENGINE: explicit engine selection (DEPRECATED in the
###     docling-serve OpenAPI but still honored for older deployments).
### - DOCLING_OCR_PRESET: recommended replacement for DOCLING_OCR_ENGINE.
### - DOCLING_OCR_LANG: JSON array (e.g. ["en","zh"]) or comma-separated
###     list. Empty (default) lets the OCR engine pick its default.
### - DOCLING_DO_FORMULA_ENRICHMENT: when true, the code-formula model runs
###     and `texts[*].label="formula"` items carry LaTeX in `text`. Default
###     false because the model may not be present on every deployment;
###     adapter falls back to plain-text formulas when disabled.
###
### Polling budget (server-side long-poll; client does NOT add extra sleep):
### - DOCLING_POLL_INTERVAL_SECONDS: ``?wait=N`` value sent to
###     /v1/status/poll/{task_id}. Larger N = fewer round trips per parse;
###     bound by your reverse-proxy idle timeout. Default 5.
### - DOCLING_MAX_POLLS: max polling rounds before raising TimeoutError.
###     Worst-case wall-clock budget ≈
###     DOCLING_POLL_INTERVAL_SECONDS × DOCLING_MAX_POLLS. Default 240
###     (≈ 20 minutes at wait=5s); raise for very large PDFs.
###
### Bundle cache controls:
### - DOCLING_ENGINE_VERSION: recorded in <base>.docling_raw/_manifest.json.
###     与记录值不匹配时会强制缓存过期 → 重新下载。
###     留空跳过此检查。
### - LIGHTRAG_FORCE_REPARSE_DOCLING: when truthy ("1"/"true"), bypass the
###     docling raw cache and re-upload on every parse_docling call.
### - DOCLING_BBOX_ATTRIBUTES: override the doc-level bbox_attributes
###     written into <base>.blocks.jsonl meta. Default
###     {"origin":"LEFTBOTTOM"} matches docling's default coordinate system.
DOCLING_ENDPOINT=http://localhost:5001
DOCLING_DO_OCR=true
DOCLING_FORCE_OCR=true
DOCLING_DO_FORMULA_ENRICHMENT=false
# DOCLING_OCR_ENGINE=auto
# DOCLING_OCR_PRESET=auto
# DOCLING_OCR_LANG=
# DOCLING_POLL_INTERVAL_SECONDS=5
# DOCLING_MAX_POLLS=240
# DOCLING_ENGINE_VERSION=
# LIGHTRAG_FORCE_REPARSE_DOCLING=false
# DOCLING_BBOX_ATTRIBUTES={"origin":"LEFTBOTTOM"}

### 触发实体/关系合并时 LLM 摘要的摘要段数或 token 数（建议至少为 3）
# FORCE_LLM_SUMMARY_ON_MERGE=8
### 触发 LLM 摘要的最大描述 token 大小
# SUMMARY_MAX_TOKENS = 1200
### 推荐的 LLM 摘要输出长度（token）
# SUMMARY_LENGTH_RECOMMENDED=600
### 发送给 LLM 用于描述摘要的最大上下文长度
# SUMMARY_CONTEXT_SIZE=12000
### 实体抽取输入上下文允许的最大 token 数
# MAX_EXTRACT_INPUT_TOKENS=20480

### 多模态上下文预算（每半段的 token 上限，用于
### 注入 VLM 和提取 prompt 的 `leading` / `trailing` 文本）。
### 在 analyze_multimodal 入口处计算；两半段相互独立，
### 部署可按需调整前后上下文比例。
# SURROUNDING_LEADING_MAX_TOKENS=2000
# SURROUNDING_TRAILING_MAX_TOKENS=2000

### LLM 每次响应输出的实体+关系行/记录总数上限
# MAX_EXTRACTION_RECORDS=100
### LLM 每次响应输出的实体行/对象数上限
# MAX_EXTRACTION_ENTITIES=40

### 启用 JSON 结构化输出的实体提取（注意：JSON 输出延迟更高但可靠性更好）
### 默认行为：当 ENTITY_EXTRACTION_USE_JSON 未设置时，JSON 输出关闭
ENTITY_EXTRACTION_USE_JSON=true

### 可选的实体类型引导和提取示例外部 YAML 配置文件
### 配置文件从 PROMPT_DIR/entity_type 加载（PROMPT_DIR 默认为 ./prompts）。
### 参考模板位于 prompts/samples/entity_type_prompt.sample.yml；
### 也可以在运行时通过 Python 代码覆盖引导文本：
###   addon_params={"entity_types_guidance": "- CustomType: description..."}
# ENTITY_TYPE_PROMPT_FILE=entity_type_prompt.yml

### 控制向量库和图数据库中存储的最大 chunk_ids 数量
# MAX_SOURCE_IDS_PER_ENTITY=300
# MAX_SOURCE_IDS_PER_RELATION=300
### 控制 chunk_ids 限制方式：FIFO、KEEP
###    FIFO：先进先出
###    KEEP：保留最旧（合并操作更少、速度更快）
# SOURCE_IDS_LIMIT_METHOD=FIFO

# entity/relation 的 file_path 字段中最多保存多少个文件路径（仅用于展示，不影响查询性能）
# MAX_FILE_PATHS=100

### 受保护 PDF 文件的解密密码
# PDF_DECRYPT_PASSWORD=your_pdf_password_here

###############################
### 并发配置
###############################
### LLM 最大并发请求数（同时作用于查询和文档处理）
MAX_ASYNC=4
### 并行处理文档数量（建议 2~10，推荐使用 MAX_ASYNC/3）
MAX_PARALLEL_INSERT=2
### 可选的按阶段文档管线并发数
# MAX_PARALLEL_PARSE_NATIVE=5
# MAX_PARALLEL_PARSE_MINERU=1
# MAX_PARALLEL_PARSE_DOCLING=1
# MAX_PARALLEL_ANALYZE=5
### 可选的管线工作器队列大小
# QUEUE_SIZE_DEFAULT=100
# QUEUE_SIZE_INSERT=4
### Embedding 最大并发请求数
# EMBEDDING_FUNC_MAX_ASYNC=8
### 单次请求发送给 Embedding 的 chunk 数
# EMBEDDING_BATCH_NUM=10

###########################################################################
### LLM 配置
### LLM_BINDING 类型：openai、ollama、lollms、azure_openai、bedrock、gemini
### LLM_BINDING_HOST：服务端点（如果使用 openai 或 gemini SDK 提供的默认端点，可留空）
### LLM_BINDING_API_KEY：API 密钥
### 如果 LightRAG 运行在 Docker 中：
###    LLM_BINDING_HOST 中请使用 host.docker.internal，而不是 localhost
###########################################################################
### 所有 llm 的请求超时设置（对 Ollama 来说，0 表示不超时）
# LLM_TIMEOUT=180

LLM_BINDING=openai
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=your_api_key
LLM_MODEL=gpt-5-mini

### use the following command to see all support options for OpenAI, azure_openai or OpenRouter
### lightrag-server --llm-binding openai --help
### OpenAI 专属参数
# OPENAI_LLM_REASONING_EFFORT=minimal
### OpenRouter 专属参数
# OPENAI_LLM_EXTRA_BODY='{"reasoning": {"enabled": false}}'
### 由 vLLM 部署的 Qwen3 专属参数
# OPENAI_LLM_EXTRA_BODY='{"chat_template_kwargs": {"enable_thinking": false}}'

### OpenAI 兼容 API 专属参数
### Increased temperature values may mitigate infinite inference loops in certain LLM, such as Qwen3-30B.
# OPENAI_LLM_TEMPERATURE=0.9
### Set the max_tokens to mitigate endless output of some LLM (less than LLM_TIMEOUT * llm_output_tokens/second, i.e. 9000 = 180s * 50 tokens/s)
### Typically, max_tokens does not include prompt content
### For vLLM/SGLang and most of OpenAI compatible API provider
# OPENAI_LLM_MAX_TOKENS=9000
### For OpenAI o1-mini or newer modles utilizes max_completion_tokens instead of max_tokens
# OPENAI_LLM_MAX_COMPLETION_TOKENS=9000

### Azure OpenAI example
### Use deployment name as model name or set AZURE_OPENAI_DEPLOYMENT instead
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# # LLM_BINDING=azure_openai
# # LLM_BINDING_HOST=https://xxxx.openai.azure.com/
# # LLM_BINDING_API_KEY=your_api_key
# # LLM_MODEL=my-gpt-mini-deployment

### Openrouter example
# # LLM_BINDING=openai
# # LLM_BINDING_HOST=https://openrouter.ai/api/v1
# # LLM_BINDING_API_KEY=your_api_key
# # LLM_MODEL=google/gemini-2.5-flash

### Google Gemini example (AI Studio)
# # LLM_BINDING=gemini
### DEFAULT_GEMINI_ENDPOINT 表示由 SDK 自动选择端点
# # LLM_BINDING_HOST=DEFAULT_GEMINI_ENDPOINT
# # LLM_BINDING_API_KEY=your_gemini_api_key
# # LLM_MODEL=gemini-flash-latest

### use the following command to see all support options for OpenAI, azure_openai or OpenRouter
### lightrag-server --llm-binding gemini --help
### Gemini Specific Parameters
# GEMINI_LLM_MAX_OUTPUT_TOKENS=9000
# GEMINI_LLM_TEMPERATURE=0.7
### Enable or disable thinking
# GEMINI_LLM_THINKING_CONFIG='{"thinking_budget": -1, "include_thoughts": true}'
# # GEMINI_LLM_THINKING_CONFIG='{"thinking_budget": 0, "include_thoughts": false}'

### Google Vertex AI example
### Vertex AI use GOOGLE_APPLICATION_CREDENTIALS instead of API-KEY for authentication
# # LLM_BINDING=gemini
# # LM_BINDING_HOST=https://aiplatform.googleapis.com
### or use DEFAULT_GEMINI_ENDPOINT to select endpoint based on project and location automatically
# # LLM_BINDING_HOST=DEFAULT_GEMINI_ENDPOINT
# # LLM_MODEL=gemini-2.5-flash
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT='your-project-id'
# GOOGLE_CLOUD_LOCATION='us-central1'
# GOOGLE_APPLICATION_CREDENTIALS='/Users/xxxxx/your-service-account-credentials-file.json'

### Ollama example
# # LLM_BINDING=ollama
# # LLM_BINDING_HOST=http://localhost:11434
# # LLM_MODEL=qwen3.5:9b

### use the following command to see all support options for Ollama LLM
### lightrag-server --llm-binding ollama --help
### Ollama Server Specific Parameters
### OLLAMA_LLM_NUM_CTX must be provided, and should at least larger than MAX_TOTAL_TOKENS + 2000
OLLAMA_LLM_NUM_CTX=32768
### Set the max_output_tokens to mitigate endless output of some LLM (less than LLM_TIMEOUT * llm_output_tokens/second, i.e. 9000 = 180s * 50 tokens/s)
# OLLAMA_LLM_NUM_PREDICT=9000
# OLLAMA_LLM_TEMPERATURE=0.85
### Stop sequences for Ollama LLM
# OLLAMA_LLM_STOP='["</s>", "<|EOT|>"]'

### Bedrock Specific Parameters
### Bedrock 从环境变量 / AWS 凭证链读取 AWS 凭证。
# # LLM_BINDING=bedrock
# # LLM_BINDING_HOST=DEFAULT_BEDROCK_ENDPOINT
# # LLM_MODEL=us.amazon.nova-lite-v1:0
### Authentication (choose ONE of the following two approaches):
### Bedrock API key (bearer token). Bedrock ignores LLM_BINDING_API_KEY;
### set AWS_BEARER_TOKEN_BEDROCK directly before startup. This is a
### process-level AWS SDK setting and cannot be overridden per role.
# AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key
### SigV4 credentials (classic IAM user / STS / instance profile).
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_SESSION_TOKEN=your_optional_aws_session_token
### Region is required for both auth modes (Bedrock endpoints are regional).
# AWS_REGION=us-west-1
### use the following command to see all supported options for Bedrock
### lightrag-server --llm-binding bedrock --help
### Bedrock Converse API inferenceConfig (leave max_tokens unset to use the model default)
# BEDROCK_LLM_TEMPERATURE=1.0
# BEDROCK_LLM_MAX_TOKENS=9000
# BEDROCK_LLM_TOP_P=1.0
# BEDROCK_LLM_STOP_SEQUENCES='["</s>"]'
### Model-specific request fields forwarded as Converse API additionalModelRequestFields
# BEDROCK_LLM_EXTRA_FIELDS='{"reasoningConfig": {"type": "enabled", "maxReasoningEffort": "low"}}'

###########################################################################
### 可选的按角色 LLM/VLM 覆盖配置
### 未设置时，每个角色回退到上述基础 LLM_* 配置。
### 可用角色：EXTRACT、KEYWORD、QUERY、VLM
### 注意：{ROLE}_MAX_ASYNC_LLM 未设置时，继承基础 MAX_ASYNC
### 的运行时值（不会受下方注释掉的默认值限制）。
### 角色超时变量格式：{ROLE}_LLM_TIMEOUT
###   如 EXTRACT_LLM_TIMEOUT、KEYWORD_LLM_TIMEOUT、QUERY_LLM_TIMEOUT、
###        VLM_LLM_TIMEOUT。
### EXTRACT、KEYWORD、QUERY 的跨供应商配置、供应商
### 选项和继承规则，详见：
###   docs/RoleSpecificLLMConfiguration.md
###   docs/RoleSpecificLLMConfiguration-zh.md
###########################################################################
### VLM 多模态分析总开关（i/t/e 项）。
### 为 false 时，无论文档的 process_options 如何，
### 所有多模态项都会被跳过并发出警告。为 true 时，VLM_LLM_BINDING（或基础
### LLM_BINDING）必须支持视觉；lollms 会在启动时被拒绝。
# VLM_PROCESS_ENABLE=false

### 示例：使用专用模型/供应商进行多模态分析
# VLM_LLM_BINDING=openai
# VLM_LLM_MODEL=your_vlm_model
# VLM_LLM_BINDING_HOST=https://api.example.com/v1
# VLM_LLM_BINDING_API_KEY=your_vlm_api_key
# VLM_MAX_ASYNC_LLM=4
# VLM_LLM_TIMEOUT=180
### Maximum image bytes sent to VLM (5242880=5MB)
# VLM_MAX_IMAGE_BYTES=5242880

#######################################################################################
### Embedding 配置（处理第一个文件后不应修改）
### EMBEDDING_BINDING：ollama、openai、azure_openai、jina、lollms、bedrock
### EMBEDDING_BINDING_HOST：服务端点（如果使用默认端点，可留空）
### EMBEDDING_BINDING_API_KEY：API 密钥
### 如果 LightRAG 运行在 Docker 中：
###    uses host.docker.internal instead of localhost in EMBEDDING_BINDING_HOST
### 控制是否向 Embedding API 发送 embedding_dim 参数
###    OpenAI：设置 EMBEDDING_SEND_DIM=true 启用动态维度调整
###    OpenAI：设置 EMBEDDING_SEND_DIM=false（默认）禁用发送维度参数
###    Gemini：始终设置 EMBEDDING_SEND_DIM=true
### 控制是否使用 base64 编码格式传输 embedding（提升 OpenAI 性能）
###    OpenAI：设置 EMBEDDING_USE_BASE64=true（默认）使用 base64 编码
###    Yandex Cloud 等不支持此功能的供应商：设置 EMBEDDING_USE_BASE64=false
#######################################################################################
# EMBEDDING_TIMEOUT=30

### OpenAI 兼容 Embedding
EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=your_api_key
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=false
# EMBEDDING_USE_BASE64=true

### 可选的 Azure Embedding
### 使用 deployment 名称作为模型名，或单独设置 AZURE_EMBEDDING_DEPLOYMENT
# # EMBEDDING_BINDING=azure_openai
# # EMBEDDING_BINDING_HOST=https://xxxx.openai.azure.com/
# # EMBEDDING_API_KEY=your_api_key
# # EMBEDDING_MODEL==my-text-embedding-3-large-deployment
# # EMBEDDING_DIM=3072
# AZURE_EMBEDDING_API_VERSION=2024-08-01-preview

### Gemini Embedding
# # EMBEDDING_BINDING=gemini
# # EMBEDDING_MODEL=gemini-embedding-001
# # EMBEDDING_DIM=1536
# # EMBEDDING_TOKEN_LIMIT=2048
### DEFAULT_GEMINI_ENDPOINT 表示由 SDK 自动选择端点
# # EMBEDDING_BINDING_HOST=DEFAULT_GEMINI_ENDPOINT
# # EMBEDDING_BINDING_API_KEY=your_api_key
### Gemini embedding 需要向服务端发送维度参数
# # EMBEDDING_SEND_DIM=true

### Ollama Embedding
# # EMBEDDING_BINDING=ollama
# # EMBEDDING_BINDING_HOST=http://localhost:11434
# # EMBEDDING_BINDING_API_KEY=your_api_key
# # EMBEDDING_MODEL=qwen3-embedding:4b
# # EMBEDDING_DIM=2560
### 可选的 Ollama Embedding
OLLAMA_EMBEDDING_NUM_CTX=8192
### 使用以下命令查看 Ollama embedding 的全部支持选项
### lightrag-server --embedding-binding ollama --help

### Bedrock Embedding
### Bedrock 从环境变量 / AWS 凭证链读取 AWS 凭证。
# # EMBEDDING_BINDING=bedrock
# # EMBEDDING_BINDING_HOST=DEFAULT_BEDROCK_ENDPOINT
# # Or set EMBEDDING_BINDING_HOST to a custom Bedrock-compatible proxy/gateway URL
# # EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
# # EMBEDDING_DIM=1024
### Authentication (choose ONE of the following two approaches):
### Bedrock API key (bearer token). Bedrock ignores EMBEDDING_BINDING_API_KEY;
### set AWS_BEARER_TOKEN_BEDROCK directly before startup. This is a
### process-level AWS SDK setting and cannot be overridden per role.
# AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key
### SigV4 credentials (classic IAM user / STS / instance profile).
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_SESSION_TOKEN=your_optional_aws_session_token
### Region is required for both auth modes (Bedrock endpoints are regional).
# AWS_REGION=us-west-1

### Jina AI Embedding
# # EMBEDDING_BINDING=jina
# # EMBEDDING_BINDING_HOST=https://api.jina.ai/v1/embeddings
# # EMBEDDING_MODEL=jina-embeddings-v4
# # EMBEDDING_DIM=2048
# # EMBEDDING_BINDING_API_KEY=your_api_key

### 可选：非对称 embedding（查询/文档行为分离）
### 留空或设为 false 保持对称行为。
### 仅当所选 embedding 后端支持非对称模式时才设为 true。
# EMBEDDING_ASYMMETRIC=true
### Jina/Gemini/VoyageAI 等供应商任务绑定使用供应商参数，
### 不应配置下方前缀变量。
### BGE/E5/GTE 等基于前缀的模型需要同时设置两个前缀变量。
### 对有意不需要前缀的那一侧使用 NO_PREFIX。
### 如果有尾部空格，请用引号包裹非空值。
# EMBEDDING_DOCUMENT_PREFIX="search_document: "
# EMBEDDING_QUERY_PREFIX="search_query: "
# # EMBEDDING_DOCUMENT_PREFIX=NO_PREFIX

####################################################################
### WORKSPACE 会为所有存储类型设置 workspace 名称
### 用于隔离不同 LightRAG 实例之间的数据。
### 有效的 workspace 名称约束：a-z、A-Z、0-9 和 _
####################################################################
# WORKSPACE=

############################
### 数据存储选择
############################
### 默认存储：JSON/Nano/NetworkX（推荐用于测试部署）
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

### 向导元数据：用于在多次运行 setup 时保留 Docker 存储部署默认值
# LIGHTRAG_SETUP_POSTGRES_DEPLOYMENT=docker
# LIGHTRAG_SETUP_NEO4J_DEPLOYMENT=docker
# LIGHTRAG_SETUP_MONGODB_DEPLOYMENT=docker
# LIGHTRAG_SETUP_MONGODB_DEPLOYMENT=atlas-capable
# LIGHTRAG_SETUP_REDIS_DEPLOYMENT=docker
# LIGHTRAG_SETUP_MILVUS_DEPLOYMENT=docker
# LIGHTRAG_SETUP_QDRANT_DEPLOYMENT=docker
# LIGHTRAG_SETUP_MEMGRAPH_DEPLOYMENT=docker
# LIGHTRAG_SETUP_OPENSEARCH_DEPLOYMENT=docker

### PostgreSQL 配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_username
POSTGRES_PASSWORD='your_password'
POSTGRES_DATABASE=rag
POSTGRES_MAX_CONNECTIONS=25
### 不应设置数据库专属 workspace，仅保留用于兼容
# POSTGRES_WORKSPACE=forced_workspace_name

### 对大维度 embedding（2000+ 维度）使用 HNSW_HALFVEC。
### 需要 pgvector 扩展 >= 0.7.0。
### 向量存储类型：HNSW、HNSW_HALFVEC、IVFFlat、VCHORDRQ
POSTGRES_VECTOR_INDEX_TYPE=HNSW
POSTGRES_HNSW_M=16
POSTGRES_HNSW_EF=200
POSTGRES_IVFFLAT_LISTS=100
POSTGRES_VCHORDRQ_BUILD_OPTIONS=
POSTGRES_VCHORDRQ_PROBES=
POSTGRES_VCHORDRQ_EPSILON=1.9

### PostgreSQL 连接重试配置（网络鲁棒性）
### 新默认值（v1.4.10+）：为高可用部署优化，切换时间约 30s
### 这些默认值为 PostgreSQL 高可用部署提供开箱即用支持
###
### Number of retry attempts (1-100, default: 10)
###   - Default 10 attempts allows ~225s total retry time (sufficient for most HA scenarios)
###   - For extreme cases: increase up to 20-50
### Initial retry backoff in seconds (0.1-300.0, default: 3.0)
###   - Default 3.0s provides reasonable initial delay for switchover detection
###   - For faster recovery: decrease to 1.0-2.0
### Maximum retry backoff in seconds (must be >= backoff, max: 600.0, default: 30.0)
###   - Default 30.0s matches typical switchover completion time
###   - For longer switchovers: increase to 60-90
### Connection pool close timeout in seconds (1.0-30.0, default: 5.0)
# POSTGRES_CONNECTION_RETRIES=10
# POSTGRES_CONNECTION_RETRY_BACKOFF=3.0
# POSTGRES_CONNECTION_RETRY_BACKOFF_MAX=30.0
# POSTGRES_POOL_CLOSE_TIMEOUT=5.0

### PostgreSQL SSL 配置（可选）
# POSTGRES_SSL_MODE=require
# POSTGRES_SSL_CERT=/path/to/client-cert.pem
# POSTGRES_SSL_KEY=/path/to/client-key.pem
# POSTGRES_SSL_ROOT_CERT=/path/to/ca-cert.pem
# POSTGRES_SSL_CRL=/path/to/crl.pem

### PostgreSQL 服务端设置（用于 Supabase Supavisor）
# 用于向 PostgreSQL 连接字符串传递额外选项。
# 对于 Supabase，可能需要这样设置：
# POSTGRES_SERVER_SETTINGS='options=reference%3D[project-ref]'

# Default is 100 set to 0 to disable
# POSTGRES_STATEMENT_CACHE_SIZE=100

### Neo4j 配置
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD='your_password'
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=100
NEO4J_CONNECTION_TIMEOUT=30
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=30
NEO4J_MAX_TRANSACTION_RETRY_TIME=30
NEO4J_MAX_CONNECTION_LIFETIME=300
NEO4J_LIVENESS_CHECK_TIMEOUT=30
NEO4J_KEEP_ALIVE=true
### 不应设置数据库专属 workspace，仅保留用于兼容
# NEO4J_WORKSPACE=forced_workspace_name

### MongoDB 配置
# 对于 MongoVectorDBStorage，MONGO_URI 必须指向支持
# Atlas Search / Vector Search 的 MongoDB 端点，如 MongoDB Atlas 或 Atlas 本地版。
MONGO_URI=mongodb://localhost:27017/
MONGO_DATABASE=LightRAG
### 不应设置数据库专属 workspace，仅保留用于兼容
# MONGODB_WORKSPACE=forced_workspace_name

# 社区/本地 Docker MongoDB 示例（仅用于 KV、图谱或文档状态存储）：
# MONGO_URI=mongodb://localhost:27017/

### OpenSearch 配置
### OpenSearch 可用于所有存储类型：KV、向量、图谱、文档状态
### 连接设置（逗号分隔的 host:port 列表；不要包含 http:// 或 https://）
### 此安装向导仅支持经过身份验证的 OpenSearch 集群。
### OPENSEARCH_USE_SSL 控制是否通过 TLS 访问这些主机。
OPENSEARCH_HOSTS=localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=LightRAG2026_!@
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=false
# OPENSEARCH_TIMEOUT=30
# OPENSEARCH_MAX_RETRIES=3
### Index Settings (for 3-AZ Amazon OpenSearch Service, set replicas to 2)
# OPENSEARCH_NUMBER_OF_SHARDS=1
# OPENSEARCH_NUMBER_OF_REPLICAS=0
### k-NN Settings for Vector Storage (HNSW algorithm)
# OPENSEARCH_KNN_EF_CONSTRUCTION=200
# OPENSEARCH_KNN_M=16
# OPENSEARCH_KNN_EF_SEARCH=100
### PPL graphlookup for server-side graph traversal (auto-detected if not set)
# OPENSEARCH_USE_PPL_GRAPHLOOKUP=true
### 不应设置数据库专属 workspace，仅保留用于兼容
# OPENSEARCH_WORKSPACE=forced_workspace_name

### Milvus 配置
MILVUS_URI=http://localhost:19530
MILVUS_DB_NAME=lightrag
# MILVUS_DEVICE=cpu
# MILVUS_USER=root
# MILVUS_PASSWORD=your_password
# MILVUS_TOKEN=your_token
# Docker Milvus 内置栈所需；可从 .env 或导出的 shell 变量获取。
# MINIO_ACCESS_KEY_ID=minioadmin
# MINIO_SECRET_ACCESS_KEY=minioadmin
### 不应设置数据库专属 workspace，仅保留用于兼容
# MILVUS_WORKSPACE=forced_workspace_name

### Milvus 向量索引配置
### 索引类型：AUTOINDEX（默认）、HNSW、HNSW_SQ、HNSW_PQ、IVF_FLAT、IVF_SQ8、DISKANN
# MILVUS_INDEX_TYPE=AUTOINDEX

### 度量类型：COSINE（默认）、L2、IP
# MILVUS_METRIC_TYPE=COSINE

### HNSW / HNSW_SQ / HNSW_PQ Parameters (aligned with Milvus 2.4+ defaults)
### M: Maximum number of connections per node [2-2048], default 16
# MILVUS_HNSW_M=16
### efConstruction: Size of dynamic candidate list during build [8-512], default 360
# MILVUS_HNSW_EF_CONSTRUCTION=360
### ef: Size of dynamic candidate list during search, default 200
# MILVUS_HNSW_EF=200

### HNSW_SQ Specific Parameters (requires Milvus 2.6.8+)
### sq_type: Scalar quantization type - SQ4U, SQ6, SQ8 (default), BF16, FP16
# MILVUS_HNSW_SQ_TYPE=SQ8
### refine: Enable refinement step for higher precision, default false
# MILVUS_HNSW_SQ_REFINE=false
### refine_type: Refinement precision (must be higher than sq_type) - SQ6, SQ8, BF16, FP16, FP32
# MILVUS_HNSW_SQ_REFINE_TYPE=FP32
### refine_k: Refinement expansion factor, default 10
# MILVUS_HNSW_SQ_REFINE_K=10

### IVF_FLAT / IVF_SQ8 Parameters
### nlist: Number of cluster units [1-65536], recommended sqrt(n) for n>1M, default 1024
# MILVUS_IVF_NLIST=1024
### nprobe: Number of units to query [1-nlist], default 16
# MILVUS_IVF_NPROBE=16

### Qdrant
QDRANT_URL=http://localhost:6333
# QDRANT_DEVICE=cpu
# QDRANT_API_KEY=your-api-key
### Qdrant upsert 批处理（默认启用）
### 根据预估的 JSON 负载大小和点数拆分大批量 upsert
### 默认 16MB 保留安全余量，低于常见的 32MB 网关/请求限制
# QDRANT_UPSERT_MAX_PAYLOAD_BYTES=16777216
# QDRANT_UPSERT_MAX_POINTS_PER_BATCH=128
### 不应设置数据库专属 workspace，仅保留用于兼容
# QDRANT_WORKSPACE=forced_workspace_name

### Redis
REDIS_URI=redis://localhost:6379
REDIS_SOCKET_TIMEOUT=30
REDIS_CONNECT_TIMEOUT=10
REDIS_MAX_CONNECTIONS=100
REDIS_RETRY_ATTEMPTS=3
### 不应设置数据库专属 workspace，仅保留用于兼容
# REDIS_WORKSPACE=forced_workspace_name

### Memgraph 配置
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=
MEMGRAPH_DATABASE=memgraph
### 不应设置数据库专属 workspace，仅保留用于兼容
# MEMGRAPH_WORKSPACE=forced_workspace_name

###########################################################
### Langfuse 可观测性配置
### 仅适用于 OpenAI 兼容 API 提供的 LLM
### 安装方式：pip install lightrag-hku[observability]
### 注册地址：https://cloud.langfuse.com 或自部署
###########################################################
# LANGFUSE_SECRET_KEY=''
# LANGFUSE_PUBLIC_KEY=''
# LANGFUSE_HOST='https://cloud.langfuse.com'
# LANGFUSE_ENABLE_TRACE=true

############################
### 评测配置
############################
### RAGAS 评测模型（用于 RAG 质量评估）
### ⚠️ 重要：LLM 和 Embedding 端点都必须兼容 OpenAI
### 默认使用 OpenAI 模型进行评测

### 评测 LLM 配置
# EVAL_LLM_MODEL=gpt-4o-mini
### LLM 评测 API 密钥（未设置时回退到 OPENAI_API_KEY）
# EVAL_LLM_BINDING_API_KEY=your_api_key
### 自定义 OpenAI 兼容 LLM 评测端点（可选）
# EVAL_LLM_BINDING_HOST=https://api.openai.com/v1

### 评测 Embedding 配置
# EVAL_EMBEDDING_MODEL=text-embedding-3-large
### Embedding API 密钥（回退顺序：EVAL_LLM_BINDING_API_KEY -> OPENAI_API_KEY）
# EVAL_EMBEDDING_BINDING_API_KEY=your_embedding_api_key
### 自定义 OpenAI 兼容 Embedding 端点（回退：EVAL_LLM_BINDING_HOST）
# EVAL_EMBEDDING_BINDING_HOST=https://api.openai.com/v1

### 性能调优
### 并发评测用例数
### 较低的值可减少 API 限流问题，但会增加评测时间
# EVAL_MAX_CONCURRENT=2
### LightRAG 查询 TOP_K 参数（默认：10）
### 从知识图谱中检索的实体或关系数量
# EVAL_QUERY_TOP_K=10
### 评测 LLM 请求重试和超时设置
# EVAL_LLM_MAX_RETRIES=5
# EVAL_LLM_TIMEOUT=180

##########################################################################

### Workspace 管理
### 由 API / CLI 创建的受管 workspace 会记录在此注册表文件中。
# LIGHTRAG_WORKSPACE_REGISTRY_PATH=./workspaces/registry.sqlite3
### workspace 注册表的 SQLite busy timeout（毫秒）。
# LIGHTRAG_WORKSPACE_REGISTRY_BUSY_TIMEOUT_MS=5000
### 内存中最多保留多少个预热的 workspace 运行时。
# LIGHTRAG_MAX_CACHED_WORKSPACES=10
### 缓存的 workspace 运行时空闲多久后可被回收（秒）。
# LIGHTRAG_WORKSPACE_RUNTIME_IDLE_TTL=3600
### 启动时图/数据迁移探测的超时时间（秒）。
# LIGHTRAG_MIGRATION_PROBE_TIMEOUT_SECONDS=5
### hard-delete 前等待进行中请求排空的超时时间（秒）。
# LIGHTRAG_WORKSPACE_DRAIN_TIMEOUT=30
### 允许并发执行 hard-delete 后台任务的 worker 数量。
# LIGHTRAG_HARD_DELETE_EXECUTOR_WORKERS=2
### 是否允许免登录 / guest 会话创建 workspace。
### guest 创建的记录会写入 created_by='guest' 且 owners=['guest']。
# ALLOW_GUEST_WORKSPACE_CREATE=false

### Gunicorn keepalive 秒数（仅 Gunicorn 模式）
# KEEPALIVE=5

### 可选的 Gunicorn 专用日志输出（默认复用 lightrag.log）
# ERROR_LOG=/path/to/gunicorn-error.log
# ACCESS_LOG=/path/to/gunicorn-access.log

### 管理员用户列表
### 这些用户名会获得 admin JWT 角色，可执行 workspace hard-delete 等管理员操作。
# AUTH_ADMIN_USERS=admin

### 当启用帐户登录时，在登录页面上显示访客访问条目。
# ENABLE_GUEST_LOGIN_ENTRY=false
### 控制 guest 会话在 WebUI 中可见的顶层页签。
### 使用 JSON 数组；可选值：documents, knowledge-graph, retrieval, api
# GUEST_VISIBLE_TABS=["documents","knowledge-graph","retrieval","api"]

### Nebula Graph 配置
# NEBULA_HOSTS=127.0.0.1:9669
# NEBULA_USER=root
# NEBULA_PASSWORD=nebula
# NEBULA_SPACE=lightrag
# NEBULA_MAX_CONNECTION_POOL_SIZE=10
# NEBULA_IDLE_TIME=0
# NEBULA_HEARTBEAT_INTERVAL=30
# NEBULA_WORKSPACE=forced_workspace_name
# NEBULA_LISTENER_HOSTS=
# NEBULA_LISTENER_DISCOVERY=false
# NEBULA_SSL=false

