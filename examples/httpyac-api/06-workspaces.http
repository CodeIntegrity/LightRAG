@BASE_URL = {{$dotenv LIGHTRAG_BASE_URL}}
@API_KEY = {{$dotenv LIGHTRAG_API_KEY}}
@WORKSPACE = {{$dotenv LIGHTRAG_WORKSPACE}}
@WORKSPACE_TO_DELETE = {{$dotenv LIGHTRAG_WORKSPACE_TO_DELETE}}

# @import ./01-auth.http

### List Workspaces
# 用途：列出当前可见工作区。
# @ref login
GET {{BASE_URL}}/workspaces?include_deleted=false
Authorization: Bearer {{login.access_token}}
X-API-Key: {{API_KEY}}
LIGHTRAG-WORKSPACE: {{WORKSPACE}}
Accept: application/json

### Create Workspace
# 用途：创建一个新工作区。
# @ref login
POST {{BASE_URL}}/workspaces
Authorization: Bearer {{login.access_token}}
X-API-Key: {{API_KEY}}
LIGHTRAG-WORKSPACE: {{WORKSPACE}}
Content-Type: application/json
Accept: application/json

{
  "workspace": "httpyac-demo",
  "display_name": "httpyac demo",
  "description": "workspace created from httpyac example",
  "visibility": "public"
}

### Get Workspace
# 用途：读取单个工作区详情。
# @ref login
GET {{BASE_URL}}/workspaces/httpyac-demo
Authorization: Bearer {{login.access_token}}
X-API-Key: {{API_KEY}}
LIGHTRAG-WORKSPACE: {{WORKSPACE}}
Accept: application/json

### Workspace Stats
# 用途：查看工作区统计信息。
# @ref login
GET {{BASE_URL}}/workspaces/httpyac-demo/stats
Authorization: Bearer {{login.access_token}}
X-API-Key: {{API_KEY}}
LIGHTRAG-WORKSPACE: {{WORKSPACE}}
Accept: application/json

### Soft Delete Workspace
# 用途：将工作区标记为软删除。
# @ref login
POST {{BASE_URL}}/workspaces/{{WORKSPACE_TO_DELETE}}/soft-delete
Authorization: Bearer {{login.access_token}}
X-API-Key: {{API_KEY}}
LIGHTRAG-WORKSPACE: {{WORKSPACE}}
Accept: application/json

### Restore Workspace
# 用途：恢复已软删除的工作区。
# @ref login
POST {{BASE_URL}}/workspaces/{{WORKSPACE_TO_DELETE}}/restore
Authorization: Bearer {{login.access_token}}
X-API-Key: {{API_KEY}}
LIGHTRAG-WORKSPACE: {{WORKSPACE}}
Accept: application/json

### Hard Delete Workspace
# 用途：彻底删除工作区及其后台任务。
# @ref login
POST {{BASE_URL}}/workspaces/{{WORKSPACE_TO_DELETE}}/hard-delete
Authorization: Bearer {{login.access_token}}
X-API-Key: {{API_KEY}}
LIGHTRAG-WORKSPACE: {{WORKSPACE}}
Accept: application/json

### Workspace Operation
# 用途：查看工作区删除操作状态。
# @ref login
GET {{BASE_URL}}/workspaces/{{WORKSPACE_TO_DELETE}}/operation
Authorization: Bearer {{login.access_token}}
X-API-Key: {{API_KEY}}
LIGHTRAG-WORKSPACE: {{WORKSPACE}}
Accept: application/json
